# ─────────────────────────────────────────────────────────────
# VitrineIA US – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Region identifier ────────────────────────────────────────
REGION=CA

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ── Supabase US (separate project from BR) ───────────────────
SUPABASE_URL=https://YOUR_US_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your_us_anon_key_here
SUPABASE_SERVICE_KEY=your_us_service_role_key_here

# ── Twilio (SMS – US A2P 10DLC registered number) ────────────
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── Resend (transactional email) ─────────────────────────────
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=hello@yourdomain.com
RESEND_FROM_NAME=VitrineIA

# ── Booking (e.g. Calendly webhook secret, if used) ──────────
BOOKING_WEBHOOK_SECRET=your_webhook_secret_here

# ── Security ─────────────────────────────────────────────────
API_SECRET=your_internal_api_secret_here

# ─────────────────────────────────────────────────────────────
# IMPORTANT: BR variables stay in the BR repo only.
# This file must never contain SUPABASE_BR_* or any BR keys.
# ─────────────────────────────────────────────────────────────

# ── Anthropic (Sofia + Yasmin agents) ────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Stripe (payments) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
APP_URL_STRIPE=https://vitrineia-ca-production.up.railway.app
API_SECRET_STRIPE=your_internal_secret_here

# Price IDs — create in Stripe Dashboard as recurring + one-time prices
STRIPE_PRICE_STARTER_SETUP=price_starter_setup_id
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly_id
STRIPE_PRICE_GROWTH_SETUP=price_growth_setup_id
STRIPE_PRICE_GROWTH_MONTHLY=price_growth_monthly_id
STRIPE_PRICE_FULL_SETUP=price_full_setup_id
STRIPE_PRICE_FULL_MONTHLY=price_full_monthly_id
